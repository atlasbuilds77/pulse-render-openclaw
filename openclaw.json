{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_TOKEN"
      }
    }
  },
  "tools": {
    "allow": [
      "web_fetch",
      "web_search",
      "session_status"
    ],
    "deny": [
      "exec",
      "process",
      "read",
      "write",
      "edit",
      "apply_patch",
      "browser",
      "canvas",
      "sessions_spawn",
      "subagents",
      "message"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-v4-flash",
        "fallbacks": []
      },
      "thinkingDefault": "off"
    },
    "list": [
      {
        "id": "pulse",
        "name": "Pulse",
        "workspace": "/app/workspace",
        "model": {
          "primary": "deepseek/deepseek-v4-flash",
          "fallbacks": []
        },
        "tools": {
          "allow": [
            "web_fetch",
            "web_search",
            "session_status"
          ],
          "deny": [
            "exec",
            "process",
            "read",
            "write",
            "edit",
            "apply_patch",
            "browser",
            "canvas",
            "sessions_spawn",
            "subagents",
            "message"
          ]
        },
        "groupChat": {
          "mentionPatterns": [
            "pulse",
            "@pulse"
          ]
        },
        "thinkingDefault": "off"
      }
    ]
  },
  "bindings": [
    {
      "match": {
        "channel": "discord"
      },
      "agentId": "pulse"
    }
  ],
  "channels": {
    "discord": {
      "enabled": true,
      "token": {
        "source": "env",
        "provider": "default",
        "id": "DISCORD_BOT_TOKEN"
      },
      "groupPolicy": "open",
      "dmPolicy": "open",
      "replyToMode": "first",
      "allowFrom": [
        "*"
      ],
      "guilds": {
        "*": {
          "requireMention": true,
          "ignoreOtherMentions": true
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "deepseek": {
        "enabled": true
      },
      "discord": {
        "enabled": true
      }
    }
  }
}
