{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_TOKEN"
      }
    }
  },
  "tools": {
    "profile": "minimal",
    "allow": [
      "web_fetch",
      "web_search",
      "x_search",
      "session_status"
    ],
    "deny": [
      "exec",
      "process",
      "read",
      "write",
      "edit",
      "apply_patch",
      "browser",
      "canvas",
      "sessions_spawn",
      "subagents",
      "message"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4",
        "fallbacks": [
          "openai/gpt-4.1-mini"
        ]
      }
    },
    "list": [
      {
        "id": "pulse",
        "name": "Pulse",
        "workspace": "/app/workspace",
        "model": {
          "primary": "openai/gpt-5.4",
          "fallbacks": [
            "openai/gpt-4.1-mini"
          ]
        },
        "tools": {
          "profile": "minimal",
          "allow": [
            "web_fetch",
            "web_search",
            "x_search",
            "session_status"
          ],
          "deny": [
            "exec",
            "process",
            "read",
            "write",
            "edit",
            "apply_patch",
            "browser",
            "canvas",
            "sessions_spawn",
            "subagents",
            "message"
          ]
        },
        "groupChat": {
          "mentionPatterns": [
            "pulse",
            "@pulse"
          ]
        }
      }
    ]
  },
  "bindings": [
    {
      "match": {
        "channel": "discord"
      },
      "agentId": "pulse"
    }
  ],
  "channels": {
    "discord": {
      "enabled": true,
      "token": {
        "source": "env",
        "provider": "default",
        "id": "DISCORD_BOT_TOKEN"
      },
      "groupPolicy": "open",
      "dmPolicy": "open",
      "replyToMode": "first",
      "allowFrom": [
        "*"
      ],
      "guilds": {
        "*": {
          "requireMention": true,
          "ignoreOtherMentions": true
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-responses",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT-5.4",
            "api": "openai-responses",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 256000,
            "maxTokens": 32768
          },
          {
            "id": "gpt-5.5",
            "name": "GPT-5.5",
            "api": "openai-responses",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 256000,
            "maxTokens": 32768
          },
          {
            "id": "gpt-4.1-mini",
            "name": "GPT-4.1 mini",
            "api": "openai-responses",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 1047576,
            "maxTokens": 32768
          }
        ]
      }
    }
  }
}
